# ─────────────────────────────────────────────────────────────
#  Etech Backend — Environment Variables
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────

# Port the Express server listens on.
# Default: 5000
PORT=5000

# Runtime environment. Controls logging output and behaviour.
# Use "development" locally, "production" on deployed servers.
# Accepted values: development | production | test
NODE_ENV=development

# ── AI Service (Groq) ─────────────────────────────────────────

# Your Groq API key. REQUIRED.
# Get one at: https://console.groq.com → API Keys → Create API Key
# Format: starts with "gsk_"
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── CORS ──────────────────────────────────────────────────────

# Optional: restrict CORS to a specific frontend origin.
# If omitted, all origins are allowed (*).
# Production example: https://etech.yourdomain.com
# ALLOWED_ORIGIN=http://localhost:5173
