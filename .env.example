# ─────────────────────────────────────────────────────────────
#  Etech LMS Backend — Environment Variables
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# ── AI Service (Groq) ─────────────────────────────────────────
# Required. Get your key at: https://console.groq.com → API Keys
# Format: starts with "gsk_"

GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Database (MongoDB) ────────────────────────────────────────
# Required. Free cluster at: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/etech

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/etech

# ── Auth (JWT) ────────────────────────────────────────────────
# Required. Generate strong secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_SECRET and JWT_REFRESH_SECRET must be different values.

JWT_SECRET=replace_with_64_char_random_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex_string

# Optional: token expiry durations (defaults shown)
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
# Optional. If omitted, all origins are allowed.
# Set to your frontend URL in production.
# ALLOWED_ORIGIN=https://etech.yourdomain.com
